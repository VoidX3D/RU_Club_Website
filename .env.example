# Supabase (required)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Key (for scripts/seed.mjs and scripts/upload-assets.mjs)
VITE_SUPABASE_SERVICE_KEY=your-service-role-key

# Google Analytics (optional, dual-tag G-HWFPCZ4W1Q + G-HJTLGVDNYK hardcoded in analytics.ts)
VITE_GA_ID=G-HWFPCZ4W1Q
